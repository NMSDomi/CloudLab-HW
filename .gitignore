# Environment / secrets
.env
*.env
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
.claude/
*.swp
*.swo

# .NET build outputs (root-level safety net)
bin/
obj/

# Launch settings (contains local dev secrets)
**/Properties/launchSettings.json

# Node
node_modules/

# Docker override (may contain local secrets)
docker-compose.override.yml

# Terraform local state / overrides
.terraform/
*.tfstate
*.tfstate.*
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
infra/terraform/terraform.tfvars
infra/terraform/*.auto.tfvars

# Local implementation ideas (private planning docs)
.blueprints/

# Load test credentials (generated by seed_users.py)
load-tests/users.json

# Locust output artifacts
load-tests/*.html
load-tests/*.csv
load-tests/__pycache__/
load-tests/.locust_env/
