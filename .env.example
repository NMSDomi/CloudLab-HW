# ── PostgreSQL ──────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cloudhw-db

# ── JWT ────────────────────────────────────────
JWT_ISSUER=CloudHW
JWT_AUDIANCE=CloudHW User
JWT_KEY=CHANGE_ME

# ── Admin seed user ───────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=cloudhw-admin

# ── Frontend URL (for CORS) ──────────────────
FRONTEND_URL=http://localhost:82

# ── Backend URL (nginx proxy_pass target inside the frontend container) ──
# Docker Compose: use the internal service name and container port
BACKEND_URL=http://cloudhw-be:8080/
# Cloud / standalone: set to the backend service's public URL, e.g.
# BACKEND_URL=https://api-dot-your-project.ey.r.appspot.com/

# ── pgAdmin (only used by docker-compose) ────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME

# ── SMTP (Email) ─────────────────────────────
# Leave SMTP_HOST empty to log emails to console instead of sending.
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=noreply@yourdomain.com

# ── Frontend URL ─────────────────────────────
FRONTEND_URL=http://localhost:4200
